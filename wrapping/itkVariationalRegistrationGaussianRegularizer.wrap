itk_wrap_class("itk::VariationalRegistrationGaussianRegularizer" POINTER)
  # Single template parameter: TDisplacementField = Image<Vector<float,D>,D>
  foreach(d ${ITK_WRAP_IMAGE_DIMS})
    itk_wrap_template("${ITKM_IVF${d}${d}}"
                      "${ITKT_IVF${d}${d}}")
  endforeach()
itk_end_wrap_class()
